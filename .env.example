# --- required ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- optional ---
PORT=3001
ALLOWED_ORIGIN=https://yoursite.com,https://www.yoursite.com
HATE_MODEL=claude-sonnet-4-6
HATE_MOD_MODEL=claude-haiku-4-5-20251001
NODE_ENV=production

# --- optional: better news sources for daily current-events context ---
# NewsAPI free tier: https://newsapi.org (100 calls/day)
NEWSAPI_KEY=

# CryptoPanic free tier: https://cryptopanic.com/developers/api/
CRYPTOPANIC_KEY=

# --- optional: secure manual news refresh trigger ---
# If set, POST /api/refresh-events requires header: X-Refresh-Token: <this>
REFRESH_TOKEN=
